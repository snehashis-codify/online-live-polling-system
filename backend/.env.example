PORT=port on which the server runs

DATABASE_URL=full postgres connection string e.g. postgresql://user:pass@localhost:5432/dbname
DB_USER=postgres database username
DB_PASS=postgres database password
DB_NAME=postgres database name

ACCESS_TOKEN_SECRET=secret key used to sign access JWTs
ACCESS_TOKEN_EXP=access token expiry duration e.g. 15m

REFRESH_TOKEN_SECRET=secret key used to sign refresh JWTs
REFRESH_TOKEN_EXP=refresh token expiry duration e.g. 7d

FRONTEND_BASE_URL=base URL of the frontend app used to build poll shared links e.g. http://localhost:5173
